APP_NAME="LioXERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://liox.uyumsoft.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=liox_production
DB_USERNAME=forge
DB_PASSWORD=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Google Cloud SQL
# Cloud Run'da Unix socket kullanımı (Production)
# DB_CONNECTION=mysql
# DB_HOST=
# DB_SOCKET=/cloudsql/lioxerp:us-central1:lioxdb

# Google Cloud Storage
GOOGLE_CLOUD_STORAGE_BUCKET=liox-assets

# SMTP Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="LioXERP <noreply@liox.uyumsoft.com>"
MAIL_FROM_NAME="${APP_NAME}"

# CRM Integration (Uyumsoft)
CRM_LOGIN_URL=http://crmapi.erp.uyumcloud.com/UyumApi/v1/GNL/UyumLogin/
CRM_SAVE_URL=http://crmapi.erp.uyumcloud.com/UyumApi/v1/CRM/SaveCrmForm
CRM_USERNAME=
CRM_PASSWORD=

# Statamic
STATAMIC_LICENSE_KEY=
STATAMIC_CP_ROUTE=cp
STATAMIC_GUARDIAN_PERMISSIONS=
STATAMIC_GIT_ENABLED=true
STATAMIC_GIT_AUTOMATIC=true
STATAMIC_GIT_PUSH=true
STATAMIC_GIT_DISPATCH_DELAY=1
STATAMIC_GIT_QUEUE_CONNECTION=database
STATAMIC_GIT_USER_NAME="Liox Statamic Bot"
STATAMIC_GIT_USER_EMAIL="bot@liox.uyumsoft.com"
STATAMIC_FORMS_DRIVER=eloquent

# Cloudflare
CLOUDFLARE_API_KEY=
CLOUDFLARE_ZONE_ID=

# Analytics
ANALYTICS_PROPERTY_ID=
GA_MEASUREMENT_ID=

# Sentry DSN (optional)
SENTRY_LARAVEL_DSN=
